{
  "dashboard": {
    "id": null,
    "title": "BillEasy Business Metrics",
    "tags": ["billeasy", "business", "metrics"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Bills Created",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(billeasy_bills_created_total[1h])",
            "legendFormat": "Bills/Hour"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 50
                },
                {
                  "color": "red",
                  "value": 100
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Total Revenue",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(billeasy_revenue_total[1h])",
            "legendFormat": "Revenue/Hour"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1000
                },
                {
                  "color": "red",
                  "value": 5000
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Active Users",
        "type": "stat",
        "targets": [
          {
            "expr": "billeasy_active_users_total",
            "legendFormat": "Active Users"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Total Customers",
        "type": "stat",
        "targets": [
          {
            "expr": "billeasy_customers_total",
            "legendFormat": "Total Customers"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 100
                },
                {
                  "color": "red",
                  "value": 500
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Bill Creation Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(billeasy_bills_created_total[5m]) * 3600",
            "legendFormat": "Bills/Hour"
          }
        ],
        "yAxes": [
          {
            "label": "Bills per Hour"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 6,
        "title": "Revenue Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(billeasy_revenue_total[5m])",
            "legendFormat": "Revenue/5min"
          }
        ],
        "yAxes": [
          {
            "label": "Revenue ($)"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      },
      {
        "id": 7,
        "title": "Payment Status Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "billeasy_bills_by_payment_status",
            "legendFormat": "{{payment_status}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 12
        }
      },
      {
        "id": 8,
        "title": "Top Products by Revenue",
        "type": "table",
        "targets": [
          {
            "expr": "topk(10, billeasy_product_revenue_total)",
            "legendFormat": "{{product_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 12
        }
      },
      {
        "id": 9,
        "title": "Customer Acquisition",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(billeasy_customers_created_total[1h])",
            "legendFormat": "New Customers/Hour"
          }
        ],
        "yAxes": [
          {
            "label": "New Customers per Hour"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 12
        }
      },
      {
        "id": 10,
        "title": "Average Bill Value",
        "type": "stat",
        "targets": [
          {
            "expr": "billeasy_average_bill_value",
            "legendFormat": "Avg Bill Value"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 100
                },
                {
                  "color": "red",
                  "value": 500
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 20
        }
      },
      {
        "id": 11,
        "title": "GST Collected",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(billeasy_gst_collected_total[1h])",
            "legendFormat": "GST/Hour"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 100
                },
                {
                  "color": "red",
                  "value": 500
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 20
        }
      },
      {
        "id": 12,
        "title": "PDF Generation Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(billeasy_pdf_generated_total[5m]) * 60",
            "legendFormat": "PDFs/Minute"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 20
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 20
        }
      },
      {
        "id": 13,
        "title": "Failed Login Attempts",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(billeasy_failed_login_total[5m]) * 60",
            "legendFormat": "Failed Logins/Minute"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 5
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 20
        }
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "1m"
  }
}
