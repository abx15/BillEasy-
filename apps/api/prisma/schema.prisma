generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  CREDIT
}

enum GstSlab {
  ZERO
  FIVE
  TWELVE
  EIGHTEEN
  TWENTYEIGHT
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model Business {
  id            String   @id @default(cuid())
  name          String
  ownerName     String   @map("owner_name")
  email         String   @unique
  phone         String?
  address       String?
  gstNumber     String?  @map("gst_number")
  panNumber     String?  @map("pan_number")
  logoUrl       String?  @map("logo_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  users         User[]
  customers     Customer[]
  categories    Category[]
  products      Product[]
  bills         Bill[]
  stockMovements StockMovement[]

  @@map("businesses")
}

model User {
  id           String    @id @default(cuid())
  businessId   String    @map("business_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  phone        String?
  role         UserRole  @default(STAFF)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Customer {
  id            String   @id @default(cuid())
  businessId    String   @map("business_id")
  name          String
  email         String?
  phone         String?
  address       String?
  gstNumber     String?  @map("gst_number")
  panNumber     String?  @map("pan_number")
  isWalkIn      Boolean  @default(false) @map("is_walk_in")
  totalCredit   Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bills         Bill[]

  @@unique([businessId, email])
  @@map("customers")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  hsnCode     String?  @map("hsn_code")
  gstSlab     GstSlab  @default(EIGHTEEN) @map("gst_slab")
  businessId   String   @map("business_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@map("categories")
}

model Product {
  id             String    @id @default(cuid())
  businessId     String    @map("business_id")
  name           String
  description    String?
  sku            String?   @unique
  barcode        String?
  unit           String    @default("pcs")
  price          Decimal   @db.Decimal(10, 2)
  costPrice      Decimal   @db.Decimal(10, 2) @map("cost_price")
  gstSlab        GstSlab  @default(EIGHTEEN) @map("gst_slab")
  hsnCode        String?   @map("hsn_code")
  stockQuantity  Int       @default(0) @map("stock_quantity")
  minStockLevel  Int       @default(0) @map("min_stock_level")
  maxStockLevel  Int       @default(1000) @map("max_stock_level")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  categoryId     String?   @map("category_id")

  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  billItems      BillItem[]
  stockMovements StockMovement[]

  @@unique([businessId, sku])
  @@map("products")
}

model Bill {
  id                String       @id @default(cuid())
  businessId         String       @map("business_id")
  customerId         String?      @map("customer_id")
  invoiceNumber       String       @unique @map("invoice_number")
  invoiceDate         DateTime     @default(now()) @map("invoice_date")
  dueDate            DateTime?    @map("due_date")
  subtotal            Decimal      @db.Decimal(12, 2)
  discountAmount      Decimal      @default(0) @db.Decimal(12, 2) @map("discount_amount")
  gstAmount           Decimal      @default(0) @db.Decimal(12, 2) @map("gst_amount")
  totalAmount          Decimal      @db.Decimal(12, 2) @map("total_amount")
  paymentStatus        PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod        String?      @map("payment_method")
  notes               String?
  pdfUrl              String?      @map("pdf_url")
  isWalkInCustomer    Boolean      @default(false) @map("is_walk_in_customer")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  billItems      BillItem[]
  payments       Payment[]

  @@unique([businessId, invoiceNumber])
  @@map("bills")
}

model BillItem {
  id           String   @id @default(cuid())
  productName  String   @map("product_name")
  description  String?
  quantity     Decimal  @db.Decimal(10, 2)
  unit         String   @default("pcs")
  price        Decimal  @db.Decimal(10, 2)
  gstSlab      GstSlab  @default(EIGHTEEN) @map("gst_slab")
  gstAmount    Decimal  @default(0) @db.Decimal(12, 2) @map("gst_amount")
  total        Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  billId       String   @map("bill_id")
  productId    String?  @map("product_id")

  bill         Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("bill_items")
}

model Payment {
  id            String   @id @default(cuid())
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String   @map("payment_method")
  transactionId String?  @map("transaction_id")
  notes         String?
  paymentDate   DateTime @default(now()) @map("payment_date")
  createdAt     DateTime @default(now()) @map("created_at")

  billId        String   @map("bill_id")

  bill           Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model StockMovement {
  id            String        @id @default(cuid())
  movementType  MovementType  @map("movement_type")
  quantity      Int
  reason        String?
  referenceId   String?       @map("reference_id")
  referenceType String?       @map("reference_type")
  createdAt     DateTime      @default(now()) @map("created_at")

  productId     String        @map("product_id")
  businessId    String        @map("business_id")

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}
